cat > .gitignore <<'EOF'
# Terraform working directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Terraform variable files that may contain secrets
*.tfvars
*.tfvars.json

# Terraform plans
*.tfplan
tfplan

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc

# OS/editor files
.DS_Store
*.swp
*.swo
EOF
